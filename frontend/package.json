{
  "name": "meeting_ai",
  "version": "0.0.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --win",
    "preview": "electron-vite preview",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json"
  },
  "build": {
    "appId": "com.meetingnote.app",
    "productName": "MeetingNote",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "docx": "^9.6.1",
    "ffmpeg-static": "^5.3.0",
    "mermaid": "^11.15.0",
    "naive-ui": "^2.44.1",
    "tailwindcss": "^4.3.0",
    "vfonts": "^0.0.3",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/ffmpeg-static": "^3.0.3",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^41.5.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "typescript": "~6.0.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
