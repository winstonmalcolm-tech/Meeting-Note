{
  "manifest_version": 3,
  "name": "MeetingNote Autofill",
  "version": "1.0.0",
  "description": "Auto-fill job application forms and get AI-suggested answers using your MeetingNote profile",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:3001/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MeetingNote Autofill"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
